{
  "name": "nayax-lynx-client-js",
  "version": "0.1.1",
  "description": "Fully-typed TypeScript client for the Nayax Operational Lynx API (135 endpoints across 16 resources) — auto token refresh, pagination, retry.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/christophe77/nayax-lynx-client-js.git"
  },
  "bugs": {
    "url": "https://github.com/christophe77/nayax-lynx-client-js/issues"
  },
  "homepage": "https://github.com/christophe77/nayax-lynx-client-js#readme",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./webhooks": {
      "types": "./dist/webhooks/index.d.ts",
      "import": "./dist/webhooks/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run typecheck && npm test && npm run build"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "nayax",
    "lynx",
    "vending",
    "telemetry",
    "api-client"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@vitest/coverage-v8": "^1.6.0",
    "tsup": "^8.0.2",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  }
}
